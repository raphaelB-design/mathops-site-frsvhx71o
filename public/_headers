# Security headers. Most static hosts (Netlify, Cloudflare Pages and Skip's
# static hosting) read this file. If your host ignores it, replicate these
# headers in the host's config / a reverse proxy.

/*
  Content-Security-Policy: default-src 'self'; img-src 'self' https://img.usecurling.com data:; connect-src 'self' https://qzdsxtqskwrslsxodexc.supabase.co https://www.google-analytics.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://goskip.dev; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload